# n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change-me-to-a-random-string
TIMEZONE=Europe/Rome

# Moodle Web Services
MOODLE_URL=http://vektra-moodle
MOODLE_WS_TOKEN=your-moodle-ws-token

# Vektra API
VEKTRA_API_URL=http://vektra-stack-vektra-1:8000
VEKTRA_API_KEY=your-vektra-ingest-api-key

# Polling
INGEST_CRON=*/5 * * * *

# Optional: filter to specific course IDs (comma-separated, empty = all)
MOODLE_COURSE_IDS=
