# n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change-me-to-a-random-string
TIMEZONE=Europe/Rome

# Moodle Web Services
MOODLE_URL=http://vektra-moodle
MOODLE_WS_TOKEN=your-moodle-ws-token

# Vektra API
VEKTRA_API_URL=http://vektra-stack-vektra-1:8000
VEKTRA_API_KEY=your-vektra-ingest-api-key

# Polling
INGEST_CRON=*/5 * * * *

# Safety: skip mass deletions when Moodle returns an empty file list for a
# course that previously had >= DELETION_SAFETY_THRESHOLD documents in state.
# Default 3. Set to 0 to disable the safety net (deletions always run as
# computed by the diff). Useful to lower for very small test courses.
DELETION_SAFETY_THRESHOLD=3
